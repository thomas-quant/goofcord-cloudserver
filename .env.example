CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://localhost:3000
MONGO_URI=mongodb://127.0.0.1:27017/goofcord
PORT=3000

# Docker host port (the container always receives PORT).
HOST_PORT=3000
MONGO_PORT=27017

# MongoDB connects fail quickly rather than buffering requests indefinitely.
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Request and session controls.
MAX_REQUEST_BODY_BYTES=1048576
SESSION_TOUCH_INTERVAL_MS=900000
RATE_LIMIT_MAX_KEYS=10000
IP_RATE_LIMIT=120
IP_RATE_WINDOW_MS=60000
CALLBACK_RATE_LIMIT=20
CALLBACK_RATE_WINDOW_MS=60000
SESSION_RATE_LIMIT=60
SESSION_RATE_WINDOW_MS=60000

# Remote KDF. Each active worker uses 64 MiB for Argon2 plus runtime and cloud
# decode overhead. Local HTTP is an explicit direct-loopback development escape.
KDF_GLOBAL_CONCURRENCY=1
KDF_JOB_TIMEOUT_MS=30000
KDF_ALLOW_INSECURE_LOCALHOST=false

# Set true behind a TLS-terminating proxy only. List only that proxy's source
# addresses/CIDRs; direct public access must be blocked in deployed mode.
ENFORCE_HTTPS=false
TRUSTED_PROXY_CIDRS=
